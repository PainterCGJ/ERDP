{
    "version": "0.2.0",
    "configurations": [
        {
            "cwd": "${workspaceRoot}",
            "executable": "${workspaceRoot}/build/flash/flash.elf",
            "name": "Cortex-Debug (STLink)",
            "request": "launch",
            "type": "cortex-debug",
            "servertype": "openocd",
            "configFiles": [
                "Scripts/OpenOCD/openocd_stm32f4_stlink.cfg"
            ],
            "searchDir": [
                "D:/Material/environment/Tools/xpack-openocd-0.11.0-3/scripts"
            ],
            "runToEntryPoint": "main",
            "showDevDebugOutput": "none",
            "preLaunchTask": "build",
            "rttConfig": {
                "enabled": true,
                "polling_interval": 1,
                "address": "auto",
                "decoders": [
                    {
                        "label": "",
                        "port": 0,
                        "type": "console"
                    }
                ]
            }
        }
    ]
}
