CompileFlags:
  Add:
    - "--target=arm-none-eabi"
    - "--sysroot=D:/Material/environment/Tools/arm-gnu-toolchain-13.2.Rel1-mingw-w64-i686-arm-none-eabi/arm-none-eabi"
    - "-DSTM32F40_41xxx"
    - "-DSTM32F4XX"
    - "-DUSE_STDPERIPH_DRIVER"
    - "-DGD32F470"
    - "-DGD32F4XX"
    - "-mcpu=cortex-m4"
    - "-mthumb"
    - "-mfpu=fpv4-sp-d16"
    - "-mfloat-abi=hard"
  Remove:
    - "-mabi=*"
    - "-mfloat-abi=*"

Index:
  Background: Build
