{
    "version": 3,
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "arm-none-eabi-gcc",
                "CMAKE_CXX_COMPILER": "arm-none-eabi-g++",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "debug-base",
            "inherits": "base",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "release-base",
            "inherits": "base",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "cortex-m4-debug",
            "inherits": "debug-base",
            "hidden": true,
            "cacheVariables": {
                "CPU_TYPE": "cortex-m4",
                "CPU_PARAMETERS": "-mcpu=cortex-m4 -mthumb -mfpu=fpv4-sp-d16 -mfloat-abi=hard -Og -g3"
            }
        },
        {
            "name": "cortex-m4-release",
            "inherits": "release-base",
            "hidden": true,
            "cacheVariables": {
                "CPU_TYPE": "cortex-m4",
                "CPU_PARAMETERS": "-mcpu=cortex-m4 -mthumb -mfpu=fpv4-sp-d16 -mfloat-abi=hard -O3 -DNDEBUG"
            }
        },
        {
            "name": "cortex-m3-debug",
            "inherits": "debug-base",
            "hidden": true,
            "cacheVariables": {
                "CPU_TYPE": "cortex-m3",
                "CPU_PARAMETERS": "-mcpu=cortex-m3 -mthumb -Og -g3"
            }
        },
        {
            "name": "cortex-m3-release",
            "inherits": "release-base",
            "hidden": true,
            "cacheVariables": {
                "CPU_TYPE": "cortex-m3",
                "CPU_PARAMETERS": "-mcpu=cortex-m3 -mthumb -O3 -DNDEBUG"
            }
        },
        {
            "name": "stm32f407vet6+freertos-debug",
            "inherits": "cortex-m4-debug",
            "displayName": "STM32F407VET6+FreeRTOS Debug",
            "description": "Debug build for STM32F407VET6 with freertos",
            "cacheVariables": {
                "RTOS_TYPE": "FREERTOS",
                "DRIVER_PATH": "${sourceDir}/Source/Kernel/Drivers/STM32F4XX/",
                "CHIP_TYPE": "STM32F407VET6",
                "DEBUGGER_TYPE": "STLINK",
                "LINKER_SCRIPT": "${sourceDir}/Source/Kernel/Drivers/STM32F4XX/Linker/STM32F407VET6_FLASH.ld",
                "STARTUP_FILE": "${sourceDir}/Source/Kernel/Drivers/STM32F4XX/CMSIS/Device/ST/STM32F4xx/Source/Templates/gcc_ride7/startup_stm32f40_41xxx.s"
            }
        },
        {
            "name": "stm32f407vet6+freertos-release",
            "inherits": "cortex-m4-release",
            "displayName": "STM32F407VET6+FreeRTOS Release",
            "description": "Release build for STM32F407VET6 with freertos",
            "cacheVariables": {
                "RTOS_TYPE": "FREERTOS",
                "DRIVER_PATH": "${sourceDir}/Source/Kernel/Drivers/STM32F4XX/",
                "CHIP_TYPE": "STM32F407VET6",
                "DEBUGGER_TYPE": "STLINK",
                "LINKER_SCRIPT": "${sourceDir}/Source/Kernel/Drivers/STM32F4XX/Linker/STM32F407VET6_FLASH.ld",
                "STARTUP_FILE": "${sourceDir}/Source/Kernel/Drivers/STM32F4XX/CMSIS/Device/ST/STM32F4xx/Source/Templates/gcc_ride7/startup_stm32f40_41xxx.s"
            }
        },
        {
            "name": "gd32f470zit6+freertos-debug",
            "inherits": "cortex-m4-debug",
            "displayName": "GD32F470ZIT6+FreeRTOS Debug",
            "description": "Debug build for GD32F470ZIT6 with freertos",
            "cacheVariables": {
                "RTOS_TYPE": "FREERTOS",
                "DRIVER_PATH": "${sourceDir}/Source/Kernel/Drivers/GD32F4XX/",
                "CHIP_TYPE": "GD32F470ZIT6",
                "DEBUGGER_TYPE": "CMSIS-DAP",
                "LINKER_SCRIPT": "${sourceDir}/Source/Kernel/Drivers/GD32F4XX/Linker/GD32F470ZIT6_FLASH.ld",
                "STARTUP_FILE": "${sourceDir}/Source/Kernel/Drivers/GD32F4XX/CMSIS/GD/GD32F4xx/Source/GCC/startup_gd32f450_470.s"
            }
        },
        {
            "name": "gd32f470zit6+freertos-release",
            "inherits": "cortex-m4-release",
            "displayName": "GD32F470ZIT6+FreeRTOS Release",
            "description": "Release build for GD32F470ZIT6 with freertos",
            "cacheVariables": {
                "RTOS_TYPE": "FREERTOS",
                "DRIVER_PATH": "${sourceDir}/Source/Kernel/Drivers/GD32F4XX/",
                "CHIP_TYPE": "GD32F470ZIT6",
                "DEBUGGER_TYPE": "CMSIS-DAP",
                "LINKER_SCRIPT": "${sourceDir}/Source/Kernel/Drivers/GD32F4XX/Linker/GD32F470ZIT6_FLASH.ld",
                "STARTUP_FILE": "${sourceDir}/Source/Kernel/Drivers/GD32F4XX/CMSIS/GD/GD32F4xx/Source/GCC/startup_gd32f450_470.s"
            }
        },
        {
            "name": "freertos-release",
            "inherits": "cortex-m4-release",
            "displayName": "FreeRTOS Release",
            "description": "Build FreeRTOS static library"
        },
        {
            "name": "freertos-debug",
            "inherits": "cortex-m4-debug",
            "displayName": "FreeRTOS Debug",
            "description": "Build FreeRTOS static library (Debug)"
        }
    ],
    "buildPresets": [
        {
            "name": "dev-base",
            "hidden": true,
            "jobs": 8
        },
        {
            "name": "stm32f407vet6+freertos-debug",
            "inherits": "dev-base",
            "configurePreset": "stm32f407vet6+freertos-debug"
        },
        {
            "name": "stm32f407vet6+freertos-release",
            "inherits": "dev-base",
            "configurePreset": "stm32f407vet6+freertos-release"
        },
        {
            "name": "gd32f470zit6+freertos-debug",
            "inherits": "dev-base",
            "configurePreset": "gd32f470zit6+freertos-debug"
        },
        {
            "name": "gd32f470zit6+freertos-release",
            "inherits": "dev-base",
            "configurePreset": "gd32f470zit6+freertos-release"
        },
        {
            "name": "rtos-base",
            "hidden": true,
            "jobs": 8,
            "targets": [
                "rtos"
            ]
        },
        {
            "name": "freertos-release",
            "inherits": "rtos-base",
            "configurePreset": "freertos-release",
            "displayName": "Build FreeRTOS Release",
            "description": "Build FreeRTOS static library"
        },
        {
            "name": "freertos-debug",
            "inherits": "rtos-base",
            "configurePreset": "freertos-debug",
            "displayName": "Build FreeRTOS Debug",
            "description": "Build FreeRTOS static library (Debug)"
        }
    ]
}